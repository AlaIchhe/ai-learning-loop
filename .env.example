# =============================================================================
# LLM 供应商配置
# =============================================================================
# 本项目支持两种模型配置方式：
#
# 方式 A（推荐）：启动应用后在「🔧 模型设置」页面可视化配置
#   - 支持添加/管理多个提供商（OpenAI、DeepSeek、硅基流动、通义千问、智谱、
#     月之暗面、Ollama 本地、自定义 OpenAI 兼容端点）
#   - 自动测试连接、按提供商分组切换、配置持久化到 .model-config.json
#   - 无需编辑本文件
#
# 方式 B：传统 .env 环境变量（向后兼容，适合脚本/CI）
#   - 取消注释以下任一方案即可；启动时自动迁移到 UI 配置
#   - 只要供应商兼容 OpenAI SDK，填入 base_url + api_key 即可
#
# 方案 1: DeepSeek（推荐，性价比最高）
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-your-deepseek-api-key

# 方案 2: OpenAI
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-your-openai-api-key

# 方案 3: 其他（Ollama / vLLM / 硅基流动 / 豆包 / 通义千问 等）
# LLM_MODEL=your-model-name
# LLM_BASE_URL=https://your-api-endpoint/v1
# LLM_API_KEY=your-api-key

# =============================================================================
# LangSmith — 可观测性与链路追踪
# =============================================================================
# 开启后在 https://smith.langchain.com 可查看每次调用的完整链路。
# 默认关闭，避免复制模板后因占位 API Key 触发追踪初始化错误。
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_your-langsmith-api-key-here
# LANGCHAIN_PROJECT=ai-learning-loop
