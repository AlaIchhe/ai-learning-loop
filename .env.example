# =============================================================================
# OpenAI API
# =============================================================================
# 用于调用 GPT-4o 等模型，三个 Agent 均依赖此项。
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# LangSmith — 可观测性与链路追踪
# =============================================================================
# 开启 LangSmith 后，每次 graph.invoke() 会自动记录：
#   - 每个 Node 的输入/输出
#   - LLM 调用的完整 Prompt 和原始 Response
#   - 每个 Node 的耗时 (latency)
#   - Token 用量统计
# 查看地址：https://smith.langchain.com

# 开启 V2 链路追踪（必须）
LANGCHAIN_TRACING_V2=true

# LangSmith API Key（从 https://smith.langchain.com/settings 获取）
LANGCHAIN_API_KEY=lsv2_pt_your-langsmith-api-key-here

# 项目名称（在 LangSmith UI 中按此名称分组显示）
LANGCHAIN_PROJECT=ai-learning-loop

# LangSmith 服务地址（默认值，可省略）
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
